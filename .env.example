# ═══════════════════════════════════════════════════════
# KlimAgent Environment Configuration
# cp .env.example .env  →  then fill in your keys
# ═══════════════════════════════════════════════════════

# ── NVIDIA NIM API Key (required) ─────────────────────
# Free at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here

# ── NVIDIA NIM Models ─────────────────────────────────
# Text / reasoning model (Agent-S planning + chat)
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# Vision / grounding model (GUI screenshot analysis)
NVIDIA_NIM_VISION_MODEL=nvidia/llama-3.2-90b-vision-instruct

# ── Server Ports ───────────────────────────────────────
PORT=3001          # Node.js Express API
BRIDGE_PORT=3002   # Python FastAPI bridge (Agent-S)
