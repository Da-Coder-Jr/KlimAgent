# ═══════════════════════════════════════════════
# KlimAgent Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── NVIDIA NIM API Key (required) ──────────────
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-your-key-here

# ── NVIDIA NIM Model (optional) ────────────────
# Default: meta/llama-3.3-70b-instruct
# See available models at: https://build.nvidia.com/explore/discover
#
# Recommended models:
#   meta/llama-3.3-70b-instruct          (fast, default)
#   nvidia/llama-3.1-nemotron-70b-instruct  (NVIDIA-optimized)
#   nvidia/llama-3.1-nemotron-ultra-253b-v1 (most capable)
#   meta/llama-3.1-405b-instruct         (very large)
#   mistralai/mixtral-8x22b-instruct-v0.1
#   mistralai/mistral-large
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# ── Server Port (optional) ──────────────────────
PORT=3001
